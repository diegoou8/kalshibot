# Copy this file to .env and fill in real values. Never commit .env to git.

# Azure SQL Database (run scripts/create_service_account.sql first)
AZURE_SQL_CONN_STR=Driver={ODBC Driver 18 for SQL Server};Server=tcp:<your-server>.database.windows.net,1433;Database=<your-database>;Uid=kalshi_bot;Pwd=<your-password>;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

# Kalshi API — demo key for paper trading
KALSHI_DEMO_KEY_ID=<your-demo-key-uuid>

# Trading mode: PAPER (simulate) or LIVE (real orders — requires explicit auth)
ENV_EXECUTION_MODE=PAPER

# Capital limits
BANKROLL=2500.0
MAX_POSITION_SIZE=50.0
DAILY_VOLUME_LIMIT=5000.0
DAILY_LOSS_LIMIT=250.0

# Timing
TRADE_CYCLE_INTERVAL_SECS=300
MONITOR_INTERVAL_SECS=120
GUMBEL_MODE=half
